# Supabase – copy to .env and fill in from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# App name shown on login page (default: "Agency Dashboard")
# VITE_APP_NAME=Agency Dashboard

# Set to "true" to skip login (public dashboard, no Supabase Auth required)
# VITE_AUTH_DISABLED=true
